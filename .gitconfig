[user]
	email = sarpuser@gmail.com
	name = Sarp User
[submodule]
	recurse = true
[push]
	recurseSubmodules = on-demand
[fetch]
	recurseSubmodules = true
[status]
	submoduleSummary = 1 
[diff]
	tool = p4merge
[merge]
	tool = p4merge
[difftool]
	prompt = false
[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
